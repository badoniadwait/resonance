generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Voice {
  id                 String        @id @default(cuid())
  orgId              String?
  name               String
  description        String?
  category           VoiceCategory @default(GENERAL)
  language           String        @default("en-US")
  variant            Voicevariant
  cloudinaryPublicId String?
  createdAt          DateTime      @default(now())
  updateAt           DateTime      @updatedAt
  generations        Generation[]

  @@index([variant])
  @@index([orgId])
}

model Generation {
  id                 String   @id @default(cuid())
  orgId              String
  voiceId            String?
  text               String
  voiceName          String
  cloudinaryPublicId String?
  temperature        Float
  topP               Float
  topK               Int
  repetitionPenalty  Float
  createdAt          DateTime @default(now())
  updateAt           DateTime @updatedAt
  voice              Voice?   @relation(fields: [voiceId], references: [id])

  @@index([orgId])
  @@index([voiceId])
}

model DeletionTombstone {
  id                 String   @id @default(cuid())
  cloudinaryPublicId String
  retryCount         Int      @default(0)
  lastError          String?
  createdAt          DateTime @default(now())
  updateAt           DateTime @updatedAt
}

enum Voicevariant {
  SYSTEM
  CUSTOM
}

enum VoiceCategory {
  AUDIOBOOK
  CONVERSATIONAL
  CUSTOMER_SERVICE
  GENERAL
  NARRATIVE
  CHARACTERS
  MEDITATION
  MOTIVATIONAL
  PODCAST
  ADVERTISING
  VOICEOVER
  CORPORATE
}
